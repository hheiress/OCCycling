"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},{"filePath":"90","messages":"91","errorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"92","usedDeprecatedRules":"48"},{"filePath":"93","messages":"94","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},"/home/migracode/Projects/OCCycling/Front-end/src/index.js",[],["95","96"],"/home/migracode/Projects/OCCycling/Front-end/src/reportWebVitals.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/App.js",["97","98"],"import React, { Fragment, useState, useEffect } from 'react';\n\nimport { toast } from 'react-toastify';\nimport 'react-toastify/dist/ReactToastify.css';\n\nimport {\n  BrowserRouter as Router,\n  Switch,\n  Route,\n  Link,\n  Redirect\n} from \"react-router-dom\";\n\nimport HomePage from './components/HomePage';\nimport Login from './components/Login';\nimport SignUp from \"./components/SignUp\"\nimport VolunteerPanel from './components/VolunteerPanel';\nimport Residents from './components/Residents/Residents';\nimport RentBicycle from './components/Rentings/RentBicycle';\nimport Rentings from './components/Rentings/Rentings';\nimport FindBike from './components/SetTimer';\nimport AddTime from './components/Rentings/AddTime';\nimport AllBicycles from './components/Bicycles/Bicycles';\nimport AddNewBicycle from './components/Bicycles/AddNewBicycle';\nimport CreateNewRenter from './components/Residents/CreateNewRenter';\nimport Dashboard from './components/Dashboard'; /* Add 19/02 */\nimport UpdateBicycle from './components/Bicycles/Update Bicycle';\nimport UpdateRenter from './components/Residents/UpdateRenter';\n\n\ntoast.configure()\n\nfunction App() {\n\n  const [isAuthenticated, setIsAuthenticated] = useState(false);\n\n  const setAuth = (boolean) => {\n    setIsAuthenticated (boolean);\n  };\n\n  async function isAuth () {\n    try {\n\n      const response = await fetch(\"http://localhost:3001/auth/verify\", {\n        method: \"GET\",\n        headers: { token: localStorage.token }\n      });\n\n      const parseRes = await response.json()\n      console.log(parseRes)\n\n      parseRes === true ? setIsAuthenticated(true) :\n      setIsAuthenticated(false);\n\n    } catch (err) {\n      console.error(err.message);\n    }\n  }\n\n  useEffect(() => {\n    isAuth()\n  })\n\n  return (\n    <Router>\n      <Switch>\n      <Route exact path=\"/login\" \n         render = {props => \n          !isAuthenticated ? ( <Login {...props} setAuth = {setAuth} /> ) : \n            ( <Redirect to = \"/dashboard\" /> ) \n        } \n      />\n      <Route exact path=\"/signup\"\n        render = {props => \n          !isAuthenticated ? ( <SignUp {...props} setAuth = {setAuth} /> ) :\n            ( <Redirect to = \"/dashboard\" /> )\n       }\n     /> \n      <Route exact path=\"/dashboard\" \n        render = {props => \n          isAuthenticated ? ( <Dashboard {...props} setAuth = {setAuth} /> ) :\n           ( <Redirect to = \"/login\" /> )\n       }\n      />  {/* Add 19/02 */}\n\n        {/* Volunteers */}\n        {/* Volunteers */}\n        <Route exact path=\"/rentbicycle\" component={RentBicycle} />\n        <Route exact path=\"/findbike\" component={FindBike} />\n        <Route exact path=\"/addtime\" component={AddTime} />\n        <Route exact path=\"/rentings\" component={Rentings} />\n        <Route exact path=\"/residents\" component={Residents} />\n        <Route exact path=\"/bicycles\" component={AllBicycles} />\n        <Route exact path=\"/addnewbicycle\" component={AddNewBicycle} />\n        <Route path=\"/updatebicycle/:id\" component={UpdateBicycle} />\n        <Route path=\"/updaterenter/:id\" component={UpdateRenter} />\n        <Route exact path= \"/createnewrenter\" component={CreateNewRenter} />\n        <Route exact path=\"/volunteerpanel\" component={VolunteerPanel} />\n        <HomePage/>\n        \n      </Switch>\n    </Router>\n  );\n}\n\nexport default App;\n","/home/migracode/Projects/OCCycling/Front-end/src/components/Login.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/HomePage.js",["99"],"import React from 'react';\nimport { Link } from \"react-router-dom\";\n\nfunction HomePage() {\n    return (\n        <>\n            <div className=\"wrapper-login\">\n                <div className=\"login\">\n                <div className=\"homepage-block\">\n                    <img src=\"/images/icon.svg\" className=\"img\" />\n                    <h2 className=\"text-center homepage-name\"> OCCycling</h2>\n                    <Link to={'/login'}>\n                        <button className=\"btn btn-lg btn-primary submit-button btn-block\" type=\"submit\">Login </button>\n                    </Link>\n                    <Link to={'/signup'}>\n                        <button className=\"btn btn-lg btn-primary btn-block\" type=\"submit\">Sign Up</button>\n                    </Link>\n                    <p className=\"text-center homepage-text\"> START YOUR WAY WITH US!</p>\n                </div>\n                </div>\n            </div>\n        </>\n    )\n}\nexport default HomePage;","/home/migracode/Projects/OCCycling/Front-end/src/components/SignUp.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/VolunteerPanel.js",["100"],"import React from 'react';\nimport { Link } from \"react-router-dom\";\n// rent a bike\n// see list of actual rentings\n// list of residents and bicycles\n// see and update list of bikes and renting history\n\nfunction VolunteerPanel() {\n    return (\n        <nav className=\"headercontainer\">\n            <div className=\"navbar\">\n                <div className=\"logo\">\n                <h1 className=\"header-name\">OCCycling</h1>\n                <img src=\"/images/icon.svg\" className=\"logo-img\" />\n                </div>\n                <div className=\"menu\">\n                    <Link to={'/rentbicycle'}>\n                        <button className=\"btn-nav\" type=\"submit\">Rent a Bicycle</button>\n                    </Link>\n                    <br />\n                    <Link to={'/rentings'}>\n                        <button className=\"btn-nav\" type=\"submit\">Rentings</button>\n                    </Link>\n                    <Link to={'/residents'}>\n                        <button className=\"btn-nav\" type=\"submit\">Residents</button>\n                    </Link>\n                    <br />\n                    <Link to={'/bicycles'}>\n                        <button className=\"btn-nav\" type=\"submit\">Bicycles</button>\n                    </Link>\n                </div>\n            </div>\n        </nav>\n    )\n}\n\nexport default VolunteerPanel;\n\n\n\n\n\n","/home/migracode/Projects/OCCycling/Front-end/src/components/Residents/CreateNewRenter.js",["101","102","103","104"],"/home/migracode/Projects/OCCycling/Front-end/src/components/Residents/Residents.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/Residents/UpdateRenter.js",["105","106","107"],"/home/migracode/Projects/OCCycling/Front-end/src/components/Rentings/Rentings.js",["108","109"],"/home/migracode/Projects/OCCycling/Front-end/src/components/Rentings/RentBicycle.js",["110","111","112"],"/home/migracode/Projects/OCCycling/Front-end/src/components/Bicycles/Bicycles.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/Bicycles/AddNewBicycle.js",["113","114"],"/home/migracode/Projects/OCCycling/Front-end/src/components/Bicycles/Update Bicycle.js",["115","116","117","118"],"/home/migracode/Projects/OCCycling/Front-end/src/components/Residents/Search.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/Rentings/FilterRenters.js",["119","120"],"/home/migracode/Projects/OCCycling/Front-end/src/components/Bicycles/SearchBicycle.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/SearchButton.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/SetTimer.js",[],"/home/migracode/Projects/OCCycling/Front-end/src/components/Rentings/AddTime.js",["121","122","123","124"],"import React, {useState} from 'react';\nimport Form from 'react-bootstrap/Form';\nimport SetTimer from '../SetTimer';\nimport RentBicycle from './RentBicycle';\n\n// const formReducer = (state, event) => {\n//         if (event.reset) {\n//           return {\n//             starting_time: '',\n//           }\n          \n//         }\n//         return {\n//           ...state,\n//           [event.name]: event.value\n//         }\n//       }\nfunction AddTime() {\n\n    const [dataForm, setTimeData] = useState();\n    const options = [\n        {\n          label: \"1 hour\",\n          value: \"1\",\n        },\n        {\n          label: \"2 hours\",\n          value: \"2\",\n        },\n        {\n          label: \"3 hours\",\n          value: \"3\",\n        },\n        {\n          label: \"4 hours\",\n          value: \"4\",\n        },\n      ];\n\n    // const hours = option.value: dataForm.;\n    Date.prototype.addHours = function(h) {\n        this.setTime(this.getTime() + (h*60*60*1000));\n        return this;\n      }\n    // alert(new Date().addHours(4));\n    \n   const handleChange = event => {\n        console.log(\"Time Selected!!\");\n        setTimeData({ \n            options: event.target.name,\n            options: event.target.value\n           \n         });\n         console.log(event.target.value);\n      }\n    return (\n            <div>\n                <h4 className=\"addtime-header mt-3\">Add Time</h4>\n                \n                <Form.Control\n                as=\"select\"\n                name=\"starting_time\"\n                onChange={handleChange}\n                value={setTimeData.starting_time}\n                required>\n                <option value=\"\">-- Select --</option>\n                        {options.map((option) => (\n                        <option value={option.value}>{option.label}</option>\n                        ))}\n              </Form.Control> \n              <div> \n            <SetTimer futureDate={new Date().addHours(4)}/>\n        </div>\n                {/* <button className=\"mt-5 btn btn-primary w-100\" type=\"submit\" onClick={handleSubmit}>Submit</button> */}\n            </div>\n     \n    )\n}\n\nexport default AddTime;","/home/migracode/Projects/OCCycling/Front-end/src/components/Dashboard.js",[],{"ruleId":"125","replacedBy":"126"},{"ruleId":"127","replacedBy":"128"},{"ruleId":"129","severity":1,"message":"130","line":1,"column":17,"nodeType":"131","messageId":"132","endLine":1,"endColumn":25},{"ruleId":"129","severity":1,"message":"133","line":10,"column":3,"nodeType":"131","messageId":"132","endLine":10,"endColumn":7},{"ruleId":"134","severity":1,"message":"135","line":10,"column":21,"nodeType":"136","endLine":10,"endColumn":67},{"ruleId":"134","severity":1,"message":"135","line":14,"column":17,"nodeType":"136","endLine":14,"endColumn":68},{"ruleId":"129","severity":1,"message":"137","line":1,"column":17,"nodeType":"131","messageId":"132","endLine":1,"endColumn":26},{"ruleId":"129","severity":1,"message":"138","line":32,"column":10,"nodeType":"131","messageId":"132","endLine":32,"endColumn":20},{"ruleId":"129","severity":1,"message":"139","line":34,"column":10,"nodeType":"131","messageId":"132","endLine":34,"endColumn":22},{"ruleId":"134","severity":1,"message":"135","line":121,"column":23,"nodeType":"136","endLine":121,"endColumn":100},{"ruleId":"129","severity":1,"message":"139","line":23,"column":12,"nodeType":"131","messageId":"132","endLine":23,"endColumn":24},{"ruleId":"140","severity":1,"message":"141","line":34,"column":51,"nodeType":"142","messageId":"143","endLine":34,"endColumn":53},{"ruleId":"134","severity":1,"message":"135","line":106,"column":27,"nodeType":"136","endLine":106,"endColumn":105},{"ruleId":"129","severity":1,"message":"133","line":3,"column":10,"nodeType":"131