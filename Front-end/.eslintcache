ubmit\">Rent a Bicycle</button>\n                    </Link>\n                    <br />\n                    <Link to={'/rentings'}>\n                        <button className=\"btn-nav\" type=\"submit\">Rentings</button>\n                    </Link>\n                    <Link to={'/residents'}>\n                        <button className=\"btn-nav\" type=\"submit\">Residents</button>\n                    </Link>\n                    <br />\n                    <Link to={'/bicycles'}>\n                        <button className=\"btn-nav\" type=\"submit\">Bicycles</button>\n                    </Link>\n                    <Link to = \"/dashboard\">Dashboard</Link>                 \n                </div>\n            </div>\n        </nav>\n    )\n}\n\nexport default VolunteerPanel;\n\n\n\n\n\n","/home/pepe/OCCycling/Front-end/src/components/SetTimer.js",[],"/home/pepe/OCCycling/Front-end/src/components/Login.js",[],"/home/pepe/OCCycling/Front-end/src/components/Rentings/AddTime.js",["118","119","120","121"],"/home/pepe/OCCycling/Front-end/src/components/SignUp.js",[],"/home/pepe/OCCycling/Front-end/src/components/ForgotPassword.js",["122"],"/home/pepe/OCCycling/Front-end/src/components/HomePage.js",["123"],"import React from 'react';\nimport { Link } from \"react-router-dom\";\n\nfunction HomePage() {\n    return (\n        <>\n            <div className=\"wrapper-login\">\n                <div className=\"login\">\n                <div className=\"homepage-block\">\n                    <img src=\"/images/icon.svg\" className=\"img\" />\n                    <h2 className=\"text-center homepage-name\"> OCCycling</h2>\n                    <Link to={'/login'}>\n                        <button className=\"btn btn-lg btn-primary submit-button btn-block\" type=\"submit\">Login </button>\n                    </Link>\n                    <Link to={'/signup'}>\n                        <button className=\"btn btn-lg btn-primary btn-block\" type=\"submit\">Sign Up</button>\n  